{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "dbt-orchestrator",
  "agent": {
    "dbt-orchestrator": {
      "mode": "primary",
      "prompt": "{file:./generated/dbt-orchestrator.prompt.md}"
    },
    "dbt-discoverer": {
      "mode": "subagent",
      "prompt": "{file:./generated/dbt-discoverer.prompt.md}"
    }
  }
}